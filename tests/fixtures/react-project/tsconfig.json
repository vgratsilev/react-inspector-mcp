{
  "compilerOptions": {
    "jsx": "preserve",
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@ui": ["src/components/index.ts"],
      "@ui/*": ["src/components/*"],
      "@features/a": ["src/feature-a/index.ts"],
      "@features/b": ["src/feature-b/index.ts"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}
