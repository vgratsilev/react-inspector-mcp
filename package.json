{
    "name": "react-inspector-mcp",
    "version": "1.0.0",
    "type": "module",
    "main": "./dist/index.js",
    "bin": {
        "react-inspector-mcp": "./dist/index.js"
    },
    "files": [
        "dist",
        "docs/REFERENCE.md"
    ],
    "scripts": {
        "dev": "tsx src/index.ts",
        "prebuild": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
        "build": "tsc",
        "start": "node dist/index.js",
        "test": "tsx --test \"tests/**/*.test.ts\"",
        "prepare": "npm run build"
    },
    "private": true,
    "keywords": [
        "mcp",
        "mcp-server",
        "react",
        "react-components",
        "typescript",
        "ts-morph",
        "components"
    ],
    "author": "Vadim Gratsilev",
    "license": "ISC",
    "homepage": "https://github.com/vgratsilev/react-inspector-mcp#readme",
    "bugs": {
        "url": "https://github.com/vgratsilev/react-inspector-mcp/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/vgratsilev/react-inspector-mcp.git"
    },
    "engines": {
        "node": ">=20"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "ts-morph": "^28.0.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/node": "^26.0.0",
        "tsx": "^4.22.4",
        "typescript": "5.9"
    },
    "description": "MCP server for inspecting React component usage, props, dependencies, and unused components."
}
